PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1
CLIENT_ORIGIN=*
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# PostgreSQL (primary / write node)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/hanapgawa
POSTGRES_SSL=false
# Optional: point to a read replica for SELECT queries. Falls back to POSTGRES_URL if unset.
# POSTGRES_READ_URL=postgresql://postgres:postgres@replica-host:5432/hanapgawa

# MongoDB (replica set recommended; readPreference=secondaryPreferred is already set in code)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=hanapgawa

# Redis (primary / write node)
REDIS_URL=redis://localhost:6379
# Optional: point to a Redis replica for read-heavy cache lookups. Falls back to REDIS_URL if unset.
# REDIS_READ_URL=redis://replica-host:6379

# Email (Gmail SMTP)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_FROM=HanapGawa <your-gmail@gmail.com>

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-client-id-here

# Media / search integrations
GIPHY_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI — at least one key required. Gemini is tried first; Groq is the fallback.
# Gemini free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Groq free tier (no credit card): https://console.groq.com/keys
GROQ_API_KEY=
